# SPDX-License-Identifier: AGPL-3.0-only
#
# Optional overrides for openboxd.service.
# Copy to /etc/openbox/openboxd.env and edit; deploy/install.sh seeds this on
# first install when the file is missing.

# SQLite database and Incus connection
OPENBOX_DATABASE=/var/lib/openbox/openbox.db
OPENBOX_INCUS_SOCKET=/var/lib/incus/unix.socket
OPENBOX_INCUS_PROJECT=openbox
OPENBOX_CONTAINER_PROFILE=openbox-container
OPENBOX_VM_PROFILE=openbox-vm

# Existing Incus storage pool name. OpenBox references the pool but does not
# create it. Use ZFS when you want copy-on-write checkpoints and warm-pool sandboxes.
OPENBOX_STORAGE_POOL=openbox

# Private API listener. Keep on loopback when Caddy or another reverse proxy
# terminates TLS in front of the owner console.
OPENBOX_API_ADDRESS=127.0.0.1:8443

# OpenBox SSH gateway (not host SSH on port 22)
OPENBOX_SSH_ADDRESS=:2222
# Public hostname clients use for SSH and openbox forward (empty disables /v1/connection ssh)
OPENBOX_SSH_PUBLIC_HOST=
OPENBOX_SSH_PUBLIC_PORT=2222
OPENBOX_SSH_HOST_KEY=/var/lib/openbox/ssh/gateway_host
OPENBOX_SSH_INSTANCE_KEY=/var/lib/openbox/ssh/instance_client
OPENBOX_SSH_KNOWN_HOSTS=/var/lib/openbox/ssh/known_instances

# Stable local owner identity (single-owner v0.1)
OPENBOX_OWNER_ID=owner-local
OPENBOX_OWNER_NAME=Local owner
